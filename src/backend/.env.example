PORT=3000
NODE_ENV=development

# Frontend origins (comma-separated)
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:3000

# Python AI microservice base URL
AI_MICROSERVICE_URL=http://127.0.0.1:8000

# Authentication secret for signing JWT tokens
JWT_SECRET=dev-only-change-this-secret

# Local file used to persist user language preference
PREFERENCES_STORE_PATH=./data/preferences.json
USERS_STORE_PATH=./data/users.json
CONSULTATIONS_STORE_PATH=./data/consultations.json

# Request guardrails
MAX_AUDIO_FILE_SIZE_MB=12
DOWNSTREAM_TIMEOUT_MS=180000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
